# ─────────────────────────────────────────────────────────────────────────────
# VoteSahayak — Environment Variables Template
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your real values.
# NEVER commit your real .env file to Git.
#
#   cp .env.example .env
#
# Get a FREE Groq API key at: https://console.groq.com/
# ─────────────────────────────────────────────────────────────────────────────

# Groq API Key (used by the React frontend Chat page via Vite)
VITE_GROQ_API_KEY=your_groq_api_key_here

# Groq API Key (used by the Python/Streamlit backend — same key, different prefix)
GROQ_API_KEY=your_groq_api_key_here
